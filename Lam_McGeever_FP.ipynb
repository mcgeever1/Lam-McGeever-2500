   "source": [
    "# Github urls for datasets\n",
    "pce_health_care_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/17049f085df3b6d5aa927ff99f2829e8fbe70a8a/Datasets/DHLCRG3Q086SBEA.csv'\n",
    "pce_food_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/4d82c3341b7c1afd971edbc68a52aeafe1707c6d/Datasets/DFXARG3M086SBEA.csv'\n",
    "pce_energy_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/48732e2febbfa7f766ab4075ef23ed06cf9346be/Datasets/DNRGRG3M086SBEA.csv'\n",
    "pce_core_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/16ed26f9fa59b72f00c8a470e3de2a9b44dec472/Datasets/PCEPILFE.csv'\n",
    "u6_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/48732e2febbfa7f766ab4075ef23ed06cf9346be/Datasets/U6RATE.csv'\n",
    "ccard_dr_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/48732e2febbfa7f766ab4075ef23ed06cf9346be/Datasets/DRCCLACBS.csv'\n",
    "csm_loan_dr_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/48732e2febbfa7f766ab4075ef23ed06cf9346be/Datasets/DRCLACBS.csv'\n",
    "mtg_dr_url = 'https://raw.githubusercontent.com/emcgeever-husky/Lam-McGeever-2500/48732e2febbfa7f766ab4075ef23ed06cf9346be/Datasets/DRSFRMACBS.csv'\n",
    "\n",
    "# Dataframes\n",
    "indicators_df = pd.read_csv(pce_health_care_url) + pd.read_csv(pce_food_url) + pd.read_csv(pce_core_url) + pd.read_csv(pce_energy_url) + pd.read_csv(u6_url)\n",
    "delinquancy_rates_df = pd.read_csv(ccard_dr_url) + pd.read_csv(csm_loan_dr_url) + pd.read_csv(mtg_dr_url)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e424e004",
   "metadata": {},
   "source": [
    "#### FRED dataset helper function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "29c182ac",
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_fred(url, name):\n",
    "    df = pd.read_csv(url, parse_dates=['observation_date'])\n",
    "    df = df.rename(columns={df.columns[1]: name, 'observation_date': 'date'})\n",
    "    return df.set_index('date')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "09ab2159",
   "metadata": {},
   "source": [
    "#### Loading the Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "a7bb2a46",
   "metadata": {},
   "outputs": [],
   "source": [
    "pce_health = load_fred(pce_health_care_url, 'pce_health')\n",
    "pce_food = load_fred(pce_food_url, 'pce_food')\n",
    "pce_energy = load_fred(pce_energy_url, 'pce_energy')\n",
    "pce_core = load_fred(pce_core_url, 'pce_core')\n",
    "u_6 = load_fred(u6_url, 'U6')\n",
    "\n",
    "ccard_dr = load_fred(ccard_dr_url, 'ccard_dr')\n",
    "csm_loan_dr = load_fred(csm_loan_dr_url, 'csm_loan_dr')\n",
    "mtg_dr = load_fred(mtg_dr_url, 'mtg_dr')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f2b894e6",
   "metadata": {},
   "source": [
    "#### Convert Monthly Datasets to Quarterly (Using Last Month of Q)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "8990210f",
   "metadata": {},
   "outputs": [],
   "source": [
    "pce_food = pce_food.resample('QS').last()\n",
    "pce_energy = pce_energy.resample('QS').last()\n",
    "u_6 = u_6.resample('QS').last()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "e53cb7b2",
   "metadata": {},
   "outputs": [],
   "source": [
    "indicators_df = pce_health.join([pce_food, pce_core, pce_energy, u_6])\n",
    "delinquancy_rates_df = ccard_dr.join([csm_loan_dr, mtg_dr])\n",
    "\n",
    "df_master = indicators_df.join(delinquancy_rates_df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "22b00454",
   "metadata": {},
   "outputs": [
    {
