   ],
   "source": [
    "# Drop any row with missing data\n",
    "df_master = df_master.dropna()\n",
    "\n",
    "print(f\"Shape of the data: {df_master.shape}\\n\")\n",
    "\n",
    "print(\"Master DataFrame:\")\n",
    "print(df_master.head())\n",
    "\n",
    "print(\"\\nNull values in each column:\")\n",
    "print(df_master.isnull().sum())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "609d61e1",
   "metadata": {},
   "source": [
    "## Data Transformations & Lag Effects"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0292df40",
   "metadata": {},
   "source": [
    "#### YoY % Change"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "a76881b1",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_master[\"pce_health_yoy\"] = df_master[\"pce_health\"].pct_change(4) * 100\n",
    "df_master[\"pce_food_yoy\"] = df_master[\"pce_food\"].pct_change(4) * 100\n",
    "df_master[\"pce_energy_yoy\"] = df_master[\"pce_energy\"].pct_change(4) * 100\n",
    "df_master[\"pce_core_yoy\"] = df_master[\"pce_core\"].pct_change(4) * 100"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f406db13",
   "metadata": {},
   "source": [
    "### Lag Effects"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "6d5ad492",
   "metadata": {},
   "outputs": [],
   "source": [
    "# PCE Healthcare\n",
    "df_master[\"pce_health_yoy_6m\"] = df_master[\"pce_health\"].shift(2)\n",
    "df_master[\"pce_health_yoy_1y\"] = df_master[\"pce_health\"].shift(4)\n",
    "df_master[\"pce_health_yoy_2y\"] = df_master[\"pce_health\"].shift(8)\n",
    "\n",
    "# PCE Food\n",
    "df_master[\"pce_food_yoy_6m\"] = df_master[\"pce_food_yoy\"].shift(2) \n",
    "df_master[\"pce_food_yoy_1y\"] = df_master[\"pce_food_yoy\"].shift(4) \n",
    "df_master[\"pce_food_yoy_2y\"] = df_master[\"pce_food_yoy\"].shift(8) \n",
    "\n",
    "# PCE Energy\n",
    "df_master[\"pce_energy_yoy_6m\"] = df_master[\"pce_energy_yoy\"].shift(2)\n",
    "df_master[\"pce_energy_yoy_1y\"] = df_master[\"pce_energy_yoy\"].shift(4)\n",
    "df_master[\"pce_energy_yoy_2y\"] = df_master[\"pce_energy_yoy\"].shift(8)\n",
    "\n",
    "# PCE Core (excluding food and energy)\n",
    "df_master[\"pce_core_yoy_6m\"] = df_master[\"pce_core_yoy\"].shift(2)\n",
    "df_master[\"pce_core_yoy_1y\"] = df_master[\"pce_core_yoy\"].shift(4)\n",
    "df_master[\"pce_core_yoy_2y\"] = df_master[\"pce_core_yoy\"].shift(8)"
   ]
  },
